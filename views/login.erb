<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Entrar - BarberConnect</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="/css/app.css">
    <script defer src="/js/app.js"></script>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
</head>
<body class="bg-gray-900 text-white">
<div id="notification" class="notification"></div>

<section class="flex items-center justify-center min-h-screen p-4">
    <div class="w-full max-w-md">
        <!-- Logo e Título -->
        <div class="text-center mb-8">
            <div class="w-16 h-16 bg-yellow-400 rounded-2xl flex items-center justify-center mx-auto mb-4 shadow-lg">
                <i class="fas fa-cut text-black text-2xl"></i>
            </div>
            <h1 class="text-3xl font-bold text-white mb-2">BarberConnect</h1>
            <p class="text-gray-400 text-sm">Conectando você às melhores barbearias</p>
        </div>


        <% if @erro %>
            <div class="bg-red-500/10 border border-red-500 text-red-300 p-3 rounded-lg mb-4">
                <%= @erro %>
            </div>
        <% end %>


        <!-- Card de Login -->
        <div class="auth-card rounded-2xl p-8 bg-gray-800 shadow-md">
            <h2 class="text-2xl font-bold mb-6 text-center text-white">Bem-vindo de volta!</h2>

            <form onsubmit="login(event)">
                <div class="space-y-6">
                    <!-- E-mail -->
                    <div class="input-group relative">
                        <input type="email" id="loginEmail" placeholder=" "
                               class="w-full bg-transparent border-2 border-gray-600 rounded-lg px-3 py-3 text-white focus:border-yellow-400 focus:outline-none peer" required>
                        <label class="absolute left-3 top-3 text-gray-400 text-sm transition-all
                                      peer-placeholder-shown:top-3 peer-placeholder-shown:text-gray-400 peer-placeholder-shown:text-sm
                                      peer-focus:top-0 peer-focus:text-yellow-400 peer-focus:text-xs">E-mail</label>
                    </div>

                    <!-- Senha -->
                    <div class="input-group relative">
                        <input type="password" id="loginPassword" placeholder=" "
                               class="w-full bg-transparent border-2 border-gray-600 rounded-lg px-3 py-3 text-white focus:border-yellow-400 focus:outline-none peer" required>
                        <label class="absolute left-3 top-3 text-gray-400 text-sm transition-all
                                      peer-placeholder-shown:top-3 peer-placeholder-shown:text-gray-400 peer-placeholder-shown:text-sm
                                      peer-focus:top-0 peer-focus:text-yellow-400 peer-focus:text-xs">Senha</label>
                    </div>

                    <!-- Lembrar-me e Esqueceu senha -->
                    <div class="flex items-center justify-between">
                        <label class="flex items-center">
                            <input type="checkbox" class="w-4 h-4 text-yellow-400 bg-transparent border-gray-600 rounded focus:ring-yellow-400">
                            <span class="ml-2 text-sm text-gray-400">Lembrar-me</span>
                        </label>
                        <a href="/recover" class="text-sm text-yellow-400 hover:text-yellow-300 font-medium">Esqueceu a senha?</a>
                    </div>
                    <form action="/" method="get">
                        <button type="submit"
                                class="w-full bg-gradient-to-r from-yellow-400 to-yellow-300 text-black py-3 rounded-lg font-semibold hover:opacity-90 transition-opacity">
                            Entrar
                        </button>
                    </form>

                </div>
            </form>

            <!-- Link para cadastro -->
            <p class="mt-6 text-center text-gray-400 text-sm">
                Não tem conta?
                <a href="/register" class="text-yellow-400 hover:text-yellow-300 font-medium">Cadastre-se</a>
            </p>
        </div>
    </div>
</section>
</body>
</html>
