<% @title = "Escolher Tipo de Cadastro - BarberConnect" %>

<div class="flex items-center justify-center min-h-screen p-4 bg-gray-900">
    <div class="w-full max-w-md text-center">
        <!-- Logo -->
        <div class="mb-8">
            <div class="w-16 h-16 bg-yellow-400 rounded-2xl flex items-center justify-center mx-auto mb-4 shadow-lg">
                <i class="fas fa-cut text-black text-2xl"></i>
            </div>
            <h1 class="text-3xl font-bold text-white mb-2">BarberConnect</h1>
            <p class="text-gray-400 text-sm">Escolha o tipo de cadastro</p>
        </div>

        <!-- Botões de Cadastro -->
        <div class="space-y-4">
            <a href="/register/client"
               class="w-full block bg-gray-800 text-white py-3 rounded-lg font-semibold hover:bg-yellow-400 hover:text-black transition-colors">
                Cliente
            </a>
            <a href="/register/barber"
               class="w-full block bg-gray-800 text-white py-3 rounded-lg font-semibold hover:bg-yellow-400 hover:text-black transition-colors">
                Barbeiro Profissional
            </a>
            <a href="/register/barbershop"
               class="w-full block bg-gray-800 text-white py-3 rounded-lg font-semibold hover:bg-yellow-400 hover:text-black transition-colors">
                Proprietário / Gerente de Barbearia
            </a>
        </div>

        <!-- Link de login -->
        <p class="mt-6 text-gray-400 text-sm">
            Já tem conta?
            <a href="/" class="text-yellow-400 hover:text-yellow-300 font-medium">Entrar</a>
        </p>
    </div>
</div>
