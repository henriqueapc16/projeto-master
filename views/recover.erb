<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Recuperar Senha - BarberConnect</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
</head>
<body class="bg-gray-900 text-white">
<div id="notification" class="notification"></div>

<section class="flex items-center justify-center min-h-screen p-4">
    <div class="w-full max-w-md">
        <!-- Logo -->
        <div class="text-center mb-8">
            <div class="w-16 h-16 bg-yellow-400 rounded-2xl flex items-center justify-center mx-auto mb-4 shadow-lg">
                <i class="fas fa-cut text-black text-2xl"></i>
            </div>
            <h1 class="text-3xl font-bold text-white mb-2">BarberConnect</h1>
            <p class="text-gray-400 text-sm">Digite seu e-mail para recuperar a senha</p>
        </div>

        <!-- Card de Recuperação -->
        <div class="auth-card rounded-2xl p-8 bg-gray-800 shadow-md">
            <h2 class="text-2xl font-bold mb-6 text-center text-white">Recuperar Senha</h2>

            <form onsubmit="recoverPassword(event)">
                <div class="space-y-6">
                    <!-- E-mail -->
                    <div class="input-group relative">
                        <input type="email" id="recoveryEmail" placeholder=" "
                               class="w-full bg-transparent border-2 border-gray-600 rounded-lg px-3 py-3 text-white focus:border-yellow-400 focus:outline-none peer" required>
                        <label class="absolute left-3 top-3 text-gray-400 text-sm transition-all
                                      peer-placeholder-shown:top-3 peer-placeholder-shown:text-gray-400 peer-placeholder-shown:text-sm
                                      peer-focus:top-0 peer-focus:text-yellow-400 peer-focus:text-xs">E-mail cadastrado</label>
                    </div>

                    <!-- Botão -->
                    <button type="submit"
                            class="w-full bg-gradient-to-r from-yellow-400 to-yellow-300 text-black py-3 rounded-lg font-semibold hover:opacity-90 transition-opacity">
                        Enviar link de recuperação
                    </button>

                    <!-- Mensagem de orientação -->
                    <p class="text-gray-400 text-sm text-center">
                        Você receberá um e-mail com as instruções para redefinir sua senha.
                    </p>

                    <!-- Link para voltar -->
                    <p class="text-gray-400 text-center text-sm">
                        Lembrou a senha?
                        <a href="/" class="text-yellow-400 hover:text-yellow-300 font-medium">Entrar</a>
                    </p>
                </div>
            </form>
        </div>
    </div>
</section>
</body>
</html>
