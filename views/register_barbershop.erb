<% @title = "Cadastrar Barbearia - BarberConnect" %>

<div class="flex items-center justify-center min-h-screen p-4 bg-gray-900">
    <div class="w-full max-w-md">
        <div class="text-center mb-8">
            <div class="w-16 h-16 bg-yellow-400 rounded-2xl flex items-center justify-center mx-auto mb-4 shadow-lg">
                <i class="fas fa-cut text-black text-2xl"></i>
            </div>
            <h1 class="text-3xl font-bold text-white mb-2">BarberConnect</h1>
            <p class="text-gray-400 text-sm">Cadastro de Barbearia / Gerente</p>
        </div>

        <div class="auth-card rounded-2xl p-8 bg-gray-800 shadow-md">
            <h2 class="text-2xl font-bold mb-6 text-center text-white">Criar conta</h2>

            <form action="/register/barbershop" method="POST" class="space-y-6">
                <!-- CNPJ -->
                <div class="input-group relative">
                    <input type="text" name="cnpj" placeholder=" " required
                           class="w-full bg-transparent border-2 border-gray-600 rounded-lg px-3 py-3 text-white focus:border-yellow-400 peer">
                    <label class="absolute left-3 top-3 text-gray-400 text-sm transition-all
                        peer-placeholder-shown:top-3 peer-placeholder-shown:text-gray-400 peer-placeholder-shown:text-sm
                        peer-focus:top-0 peer-focus:text-yellow-400 peer-focus:text-xs">CNPJ</label>
                </div>

                <!-- CPF do gerente -->
                <div class="input-group relative">
                    <input type="text" name="cpf_manager" placeholder=" " required
                           class="w-full bg-transparent border-2 border-gray-600 rounded-lg px-3 py-3 text-white focus:border-yellow-400 peer">
                    <label class="absolute left-3 top-3 text-gray-400 text-sm transition-all
                        peer-placeholder-shown:top-3 peer-placeholder-shown:text-gray-400 peer-placeholder-shown:text-sm
                        peer-focus:top-0 peer-focus:text-yellow-400 peer-focus:text-xs">CPF do gerente</label>
                </div>

                <!-- Nome completo -->
                <div class="input-group relative">
                    <input type="text" name="name" placeholder=" " required
                           class="w-full bg-transparent border-2 border-gray-600 rounded-lg px-3 py-3 text-white focus:border-yellow-400 peer">
                    <label class="absolute left-3 top-3 text-gray-400 text-sm transition-all
                        peer-placeholder-shown:top-3 peer-placeholder-shown:text-gray-400 peer-placeholder-shown:text-sm
                        peer-focus:top-0 peer-focus:text-yellow-400 peer-focus:text-xs">Nome completo</label>
                </div>

                <!-- E-mail -->
                <div class="input-group relative">
                    <input type="email" name="email" placeholder=" " required
                           class="w-full bg-transparent border-2 border-gray-600 rounded-lg px-3 py-3 text-white focus:border-yellow-400 peer">
                    <label class="absolute left-3 top-3 text-gray-400 text-sm transition-all
                        peer-placeholder-shown:top-3 peer-placeholder-shown:text-gray-400 peer-placeholder-shown:text-sm
                        peer-focus:top-0 peer-focus:text-yellow-400 peer-focus:text-xs">E-mail</label>
                </div>

                <!-- Telefone -->
                <div class="input-group relative">
                    <input type="tel" name="phone" placeholder=" " required
                           class="w-full bg-transparent border-2 border-gray-600 rounded-lg px-3 py-3 text-white focus:border-yellow-400 peer">
                    <label class="absolute left-3 top-3 text-gray-400 text-sm transition-all
                        peer-placeholder-shown:top-3 peer-placeholder-shown:text-gray-400 peer-placeholder-shown:text-sm
                        peer-focus:top-0 peer-focus:text-yellow-400 peer-focus:text-xs">Telefone</label>
                </div>

                <!-- Senha -->
                <div class="input-group relative">
                    <input type="password" name="password" placeholder=" " required
                           class="w-full bg-transparent border-2 border-gray-600 rounded-lg px-3 py-3 text-white focus:border-yellow-400 peer">
                    <label class="absolute left-3 top-3 text-gray-400 text-sm transition-all
                        peer-placeholder-shown:top-3 peer-placeholder-shown:text-gray-400 peer-placeholder-shown:text-sm
                        peer-focus:top-0 peer-focus:text-yellow-400 peer-focus:text-xs">Senha</label>
                </div>

                <!-- Confirmar senha -->
                <div class="input-group relative">
                    <input type="password" name="confirm_password" placeholder=" " required
                           class="w-full bg-transparent border-2 border-gray-600 rounded-lg px-3 py-3 text-white focus:border-yellow-400 peer">
                    <label class="absolute left-3 top-3 text-gray-400 text-sm transition-all
                        peer-placeholder-shown:top-3 peer-placeholder-shown:text-gray-400 peer-placeholder-shown:text-sm
                        peer-focus:top-0 peer-focus:text-yellow-400 peer-focus:text-xs">Confirmar senha</label>
                </div>

                <!-- Termos -->
                <div class="flex items-start">
                    <input type="checkbox" name="terms" required
                           class="w-4 h-4 text-yellow-400 bg-transparent border-gray-600 rounded focus:ring-yellow-400 mt-1">
                    <label class="ml-2 text-sm text-gray-400">
                        Concordo com os
                        <a href="/terms" class="text-yellow-400 hover:text-yellow-300">Termos de Uso</a>
                        e
                        <a href="/terms" class="text-yellow-400 hover:text-yellow-300">Política de Privacidade</a>
                    </label>
                </div>

                <!-- Botão -->
                <button type="submit"
                        class="w-full bg-gradient-to-r from-yellow-400 to-yellow-300 text-black py-3 rounded-lg font-semibold hover:opacity-90 transition-opacity">
                    Criar conta
                </button>
            </form>

            <p class="text-gray-400 text-center mt-6">
                Já tem conta?
                <a href="/" class="text-yellow-400 hover:text-yellow-300 font-medium">Entrar</a>
            </p>
        </div>
    </div>
</div>
